NODE_ENV=development
PORT=3201
LOG_LEVEL=info
INTEGRATIONS_MODE=http

DATABASE_URL="postgresql://user:password@localhost:5432/ms_calendar?schema=public"
WEB_WHITELIST_CORS=["http://localhost:4200","http://localhost:3200"]

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_PREFETCH=1

JWT_PRIVATE_KEY=replace-with-jwt-private-key
TOKEN_MS_LOGIN=replace-with-ms-login-token
TOKEN_MS_CATALOG=replace-with-ms-catalog-token
TOKEN_CLIENT=replace-with-ms-client-token
TOKEN_MS_CALENDAR=replace-with-ms-calendar-token

URL_BACK_MS_GATEWAY=http://localhost:3299
URL_BACK_MS_AUTH=http://localhost:3200
URL_NEXTJS=http://localhost:4202

REVALIDATE_TOKEN=
REVALIDATE_HMAC_SECRET=

MS_CALENDAR_NAME=calendar
MS_NAME=calendar
MS_CLIENT_NAME=client
MS_LOGIN_NAME=auth
MS_BOOKING_PAGE_NAME=bookingPage

DESCRYPT_KEY=replace-with-strong-random-value
DESCRYPT_KEY_VERSION=1

DEFAULT_ID_COMPANY_FK=
DEFAULT_COMPANY_FK=

# Optional demo overrides (used by npm run demo)
DEMO_ROLE=ROLE_OWNER
DEMO_ID_USER=
DEMO_ID_COMPANY_SELECTED=
DEMO_ID_COMPANY=
DEMO_ID_WORKSPACE=
DEMO_ID_SERVICE=
DEMO_ID_WORKER=
DEMO_ID_CLIENT=
DEMO_ID_CLIENT_WORKSPACE=
