{
  "name": "ms-calendar-gl",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node build/index.js",
    "build": "rimraf build && tsc -p tsconfig.json",
    "openapi:bundle": "npx -y @redocly/cli bundle openapi.yaml -o openapi.bundle.yaml",
    "test": "jest --runInBand",
    "test:integration": "jest --runInBand tests/integration",
    "test:integration:rabbitmq": "dotenv -e tests/integration/env/rabbitmq.integration.env -- npm exec -- jest --runInBand tests/integration/rabbitmq --testTimeout=90000",
    "it:rabbitmq:up": "docker compose -f docker-compose.integration.yml up -d",
    "it:rabbitmq:down": "docker compose -f docker-compose.integration.yml down -v",
    "it:rabbitmq:migrate": "dotenv -e tests/integration/env/rabbitmq.integration.env -- npx prisma migrate deploy",
    "start:prod": "npm run build && node build/index.js",
    "start:dev": "dotenv -e .env.development -- sh -c \"INTEGRATIONS_MODE=http nodemon src/index.ts\"",
    "predemo": "npm run openapi:bundle",
    "demo": "dotenv -e .env.development -- sh -c \"INTEGRATIONS_MODE=mock ENABLE_REDIS=false ENABLE_RABBITMQ=false ts-node ./src/scripts/print-demo.ts && INTEGRATIONS_MODE=mock ENABLE_REDIS=false ENABLE_RABBITMQ=false nodemon src/index.ts\"",
    "start:seed:dev": "dotenv -e .env.development -- sh -c \"INTEGRATIONS_MODE=http ts-node ./prisma/seed/seed.ts && INTEGRATIONS_MODE=http nodemon src/index.ts\"",
    "prisma:migrate:dev": "dotenv -e .env.development -- npx prisma migrate dev",
    "prisma:migrate:deploy": "dotenv -e .env.production -- npx prisma migrate deploy",
    "prisma:migrate:reset": "dotenv -e .env.development -- npx prisma migrate reset",
    "prisma:seed": "dotenv -e .env.development -- ts-node ./prisma/seed/seed.ts",
    "prisma:seed:prod": "dotenv -e .env.production -- ts-node ./prisma/seed/seed.ts",
    "prisma:backfill:event-sensitive:dev": "dotenv -e .env.development -- ts-node ./prisma/seed/backfill-event-sensitive-data.ts",
    "prisma:backfill:event-sensitive:prod": "dotenv -e .env.production -- ts-node ./prisma/seed/backfill-event-sensitive-data.ts",
    "prisma:generate:dev": "dotenv -e .env.development -- npx prisma generate",
    "prisma:generate:prod": "dotenv -e .env.production -- npx prisma generate",
    "prisma:pull:dev": "dotenv -e .env.development -- npx prisma db pull",
    "prisma:pull:prod": "dotenv -e .env.production -- npx prisma db pull"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/amqplib": "0.10.6",
    "@types/express": "^4.17.7",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^8.5.0",
    "@types/moment-timezone": "^0.5.30",
    "@types/node": "^14.0.27",
    "@types/node-schedule": "^2.1.7",
    "@types/sharp": "^0.32.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^8.3.0",
    "dotenv-cli": "^7.3.0",
    "jest": "^29.7.0",
    "nodemon": "^2.0.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "amqplib": "0.10.5",
    "axios": "^0.27.2",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.19.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^8.5.1",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.46",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "node-schedule": "^2.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "redis": "^4.7.0",
    "rimraf": "^3.0.2",
    "sharp": "^0.33.5",
    "ts-node": "^8.10.2",
    "uuid": "^8.3.1",
    "zod": "^4.1.0"
  }
}
