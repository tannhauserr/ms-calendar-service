generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://test_booking_rbc_user:Zx9%26Qv5%2AN3w%21Lk4%23Ts@77.37.122.79:5432/test_booking_rbc"
}

model User {
  id              String  @id @default(uuid())
  email           String  @unique
  emailGoogle     String?
  name            String  @default("")
  lastName        String? @default("")
  image           String?
  companyRoleJson Json?   @default("[]")

  createdDate DateTime  @default(now())
  updatedDate DateTime  @default(now()) @updatedAt
  deletedDate DateTime?

  UserCalendar          UserCalendar[]
  UserColor             UserColor?
  WorkerBusinessHour    WorkerBusinessHour[]
  TemporaryBusinessHour TemporaryBusinessHour[]
  UserService           UserService[]

  @@map("users")
}

model Calendar {
  id               Int       @id @default(autoincrement())
  name             String    @default("Main Calendar")
  idGoogleCalendar String?
  idCompanyFk      String
  ownerEmailGoogle String?
  channelConfig    Json?     @default("{}")
  syncToken        String?   @default("")
  createdDate      DateTime  @default(now())
  updatedDate      DateTime  @updatedAt
  deletedDate      DateTime?

  events        Event[]
  userCalendars UserCalendar[]

  // Relaciones
  @@index([idCompanyFk])
  @@map("calendars")
}

model UserCalendar {
  id           Int       @id @default(autoincrement())
  idUserFk     String // Foreign key a User
  emailGoogle  String? // Email del usuario en Google Calendar
  idCalendarFk Int // Foreign key a Calendar
  createdDate  DateTime  @default(now())
  updatedDate  DateTime  @updatedAt
  deletedDate  DateTime?

  // Relaciones
  user     User     @relation(fields: [idUserFk], references: [id], onDelete: Cascade)
  calendar Calendar @relation(fields: [idCalendarFk], references: [id], onDelete: Cascade)

  @@unique([idUserFk, idCalendarFk])
  @@map("userCalendars")
}

model UserColor {
  id                   Int     @id @default(autoincrement())
  idUserFk             String // Foreign key a User
  idEventColorGoogleFk Int? // Foreign key a EventColorGoogle
  colorHex             String? // Código hexadecimal del color

  createdDate DateTime  @default(now())
  updatedDate DateTime  @updatedAt
  deletedDate DateTime?

  // Relaciones
  user             User              @relation(fields: [idUserFk], references: [id], onDelete: Cascade)
  eventColorGoogle EventColorGoogle? @relation(fields: [idEventColorGoogleFk], references: [id], onDelete: Cascade)

  @@unique([idUserFk])
  @@map("userColors")
}

model BusinessHour {
  id          Int         @id @default(autoincrement())
  idCompanyFk String // Foreign key a Company
  weekDayType WeekDayType // Día de la semana
  startTime   DateTime?   @db.Time
  endTime     DateTime?   @db.Time
  closed      Boolean     @default(false)
  createdDate DateTime    @default(now())
  updatedDate DateTime    @updatedAt
  deletedDate DateTime?

  // Relaciones
  @@index([idCompanyFk])
  @@map("businessHours")
}

model WorkerBusinessHour {
  id          Int         @id @default(autoincrement())
  idUserFk    String // Foreign key a User
  idCompanyFk String // Foreign key a Company
  weekDayType WeekDayType
  startTime   DateTime?   @db.Time
  endTime     DateTime?   @db.Time
  closed      Boolean     @default(false)
  createdDate DateTime    @default(now())
  updatedDate DateTime    @updatedAt
  deletedDate DateTime?

  // Relaciones
  user User @relation(fields: [idUserFk], references: [id], onDelete: Cascade)

  @@index([idCompanyFk])
  @@map("workerBusinessHours")
}

model TemporaryBusinessHour {
  id          Int       @id @default(autoincrement())
  idCompanyFk String // Foreign key a Company
  idUserFk    String? // Opcional, si aplica a un usuario específico
  date        DateTime
  startTime   DateTime? @db.Time
  endTime     DateTime? @db.Time
  closed      Boolean   @default(false)
  createdDate DateTime  @default(now()) @db.Timestamptz(3)
  updatedDate DateTime  @default(now()) @updatedAt @db.Timestamptz(3)
  deletedDate DateTime?

  // Relaciones
  user User? @relation(fields: [idUserFk], references: [id], onDelete: Cascade)

  @@index([idCompanyFk])
  @@map("temporaryBusinessHours")
}

model EventColorGoogle {
  id            Int       @id @default(autoincrement())
  idColorGoogle String // Identificador del color en Google Calendar
  colorHex      String // Código hexadecimal del color
  createdDate   DateTime  @default(now())
  updatedDate   DateTime  @updatedAt
  deletedDate   DateTime?

  // Relaciones
  userColors UserColor[] // Colores de usuario vinculados

  @@unique([idColorGoogle])
  @@map("eventColorGoogle")
}

model Event {
  id               Int             @id @default(autoincrement())
  title            String
  description      String?
  startDate        DateTime
  endDate          DateTime
  idServiceFk      Int?
  idUserBotFk      Int? // Si aplica
  idUserPlatformFk String? // Si aplica
  idGoogleEvent    String? // ID en Google Calendar
  eventSourceType  EventSourceType @default(PLATFORM)
  idCalendarFk     Int // Foreign key a Calendar
  eventType        EventType       @default(APPOINTMENT)
  eventStatus      EventStatusType @default(PENDING)
  createdDate      DateTime        @default(now())
  updatedDate      DateTime        @updatedAt
  deletedDate      DateTime?

  // Relaciones
  calendar Calendar @relation(fields: [idCalendarFk], references: [id], onDelete: Cascade)
  service  Service? @relation(fields: [idServiceFk], references: [id])

  @@index([idUserBotFk])
  @@index([idUserPlatformFk])
  @@map("events")
}

model Service {
  id           Int    @id @default(autoincrement())
  idCompanyFk  String // Foreign key a Company
  name         String @db.VarChar(100)
  description  String @db.VarChar(512)
  duration     Int    @default(60)
  price        Float  @default(0)
  idCategoryFk Int? // Puede estar sin categoría

  createdDate DateTime  @default(now())
  updatedDate DateTime  @updatedAt
  deletedDate DateTime?

  // Relaciones

  category     Category?     @relation(fields: [idCategoryFk], references: [id])
  userServices UserService[]
  events       Event[]

  @@index([idCategoryFk])
  @@map("services")
}

model Category {
  id          Int       @id @default(autoincrement())
  idCompanyFk String // Foreign key a Company
  name        String    @db.VarChar(100)
  description String?   @db.VarChar(512)
  createdDate DateTime  @default(now())
  updatedDate DateTime  @updatedAt
  deletedDate DateTime?

  services Service[]

  // Relaciones
  @@index([idCompanyFk])
  @@map("categories")
}

model UserService {
  id          Int       @id @default(autoincrement())
  idUserFk    String // Foreign key a User
  idServiceFk Int // Foreign key a Service
  createdDate DateTime  @default(now())
  updatedDate DateTime  @updatedAt
  deletedDate DateTime?

  // Relaciones
  user    User    @relation(fields: [idUserFk], references: [id], onDelete: Cascade)
  service Service @relation(fields: [idServiceFk], references: [id], onDelete: Cascade)

  @@index([idUserFk])
  @@index([idServiceFk])
  @@map("userServices")
}

enum EventSourceType {
  PLATFORM
  BOT
  GOOGLE
}

enum EventType {
  APPOINTMENT // Citas regulares
  VACATION // Vacaciones
  HOLIDAY // Días festivos
  LEAVE // Bajas por enfermedad u otros permisos
  OTHER // Otros tipos de eventos
}

enum EventStatusType {
  PENDING
  CONFIRMED
  CANCELLED
}

enum WeekDayType {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}
