generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────────────────────
// EVENTOS
// - Se elimina Calendar
// - Event referencia directamente al Workspace vía idWorkspaceFk
// - RecurrenceRule también cuelga de Workspace
// ────────────────────────────────────────────────────────────────────────────

model Event {
  id                   String   @id @default(uuid())
  idGroup              String
  idCompanyFk          String
  title                String   @db.VarChar(120)
  description          String?  @db.VarChar(512)
  encryptionKeyVersion Int      @default(1)
  startDate            DateTime @db.Timestamptz(6)
  endDate              DateTime @db.Timestamptz(6)
  // idCompanyFk      String
  // idWorkspaceFk    String
  idServiceFk          String?
  idUserPlatformFk     String?
  // commentClient      String?         @db.VarChar(512)
  // isCommentRead      Boolean         @default(false)
  // eventSourceType  EventSourceType @default(PLATFORM)
  // // isEditableByClient Boolean         @default(true)
  // numberUpdates    Int?            @default(0)
  // eventStatusType  EventStatusType @default(PENDING)
  // timeZone         String   @default("Europe/Madrid") @db.VarChar(50)
  allDay               Boolean  @default(false)

  // Snapshots de servicio en el momento de crear el evento
  serviceNameSnapshot            String? @db.VarChar(100)
  servicePriceSnapshot           Float?
  serviceDiscountSnapshot        Float?
  serviceDurationSnapshot        Int?    @default(60) // minutos
  serviceMaxParticipantsSnapshot Int?    @default(1)

  createdDate        DateTime         @default(now())
  updatedDate        DateTime         @updatedAt
  deletedDate        DateTime?
  eventPurposeType   EventPurposeType @default(APPOINTMENT)
  idRecurrenceRuleFk String?

  // service        Service?        @relation(fields: [idServiceFk], references: [id])
  recurrenceRule RecurrenceRule? @relation("recurrenceRules", fields: [idRecurrenceRuleFk], references: [id])

  workerAbsence         WorkerAbsence[]
  temporaryBusinessHour TemporaryBusinessHour[]
  externalCalendarEvent ExternalCalendarEvent?
  // eventParticipant      EventParticipant[]
  // notificationPlan      NotificationPlan[]
  eventLineItem         EventLineItem[]
  groupEvents           GroupEvents?            @relation("groupEvents", fields: [idGroup], references: [id])

  @@index([idUserPlatformFk, startDate, endDate], map: "idx_events_user_start_end")
  @@index([idUserPlatformFk, endDate], map: "idx_events_user_end")
  @@index([startDate], type: Brin, map: "idx_events_start_brin")
  @@index([idServiceFk])
  @@index([idUserPlatformFk])
  @@map("events")
}

model GroupEvents {
  id                 String          @id @default(uuid())
  startDate          DateTime        @db.Timestamptz(6)
  endDate            DateTime        @db.Timestamptz(6)
  title              String          @db.VarChar(120)
  idCompanyFk        String
  idWorkspaceFk      String
  commentClient      String?         @db.VarChar(512)
  isCommentRead      Boolean         @default(false)
  description        String?         @db.VarChar(512)
  eventSourceType    EventSourceType @default(PLATFORM)
  isEditableByClient Boolean         @default(true)
  numberUpdates      Int?            @default(0)
  eventStatusType    EventStatusType @default(PENDING)
  timeZone           String          @default("Europe/Madrid") @db.VarChar(50)
  hasNotifications   Boolean         @default(false)

  eventParticipant EventParticipant[]

  createdDate DateTime  @default(now())
  updatedDate DateTime  @updatedAt
  deletedDate DateTime?

  events Event[] @relation("groupEvents")

  @@index([idWorkspaceFk])
  @@map("groupEvents")
}

model EventParticipant {
  id      String @id @default(uuid())
  // idEventFk String
  idGroup String

  idClientWorkspaceFk String?
  idClientFk          String?
  eventStatusType     EventStatusType @default(PENDING)

  createdDate DateTime  @default(now()) @db.Timestamptz(3)
  updatedDate DateTime  @default(now()) @updatedAt @db.Timestamptz(3)
  deletedDate DateTime?

  groupEvents GroupEvents? @relation(fields: [idGroup], references: [id])

  // @@index([idEventFk])
  @@index([idClientWorkspaceFk])
  @@index([idClientFk])
  // @@index([idEventFk, eventStatusType])
  @@index([idGroup, eventStatusType])
  @@map("eventParticipants")
}

model EventLineItem {
  id        String @id @default(uuid())
  idEventFk String

  // si es un addon (id que venga del ms catálogo)
  idAddonFk String?

  // snapshots genéricos (sirven para servicio o addon)
  itemNameSnapshot     String? @db.VarChar(100)
  itemPriceSnapshot    Float?
  itemDiscountSnapshot Float?
  itemDurationSnapshot Int?    @default(60)

  // profesional opcional para esta línea
  idUserFk String?

  position Int @default(0)

  event Event @relation(fields: [idEventFk], references: [id], onDelete: Cascade)

  @@index([idEventFk])
  @@map("eventLineItems")
}

model RecurrenceRule {
  id                   String               @id @default(uuid())
  idWorkspaceFk        String
  dtstart              DateTime             @db.Timestamptz(6) // inicio de la serie
  until                DateTime?            @db.Timestamptz(6) // fecha tope
  rrule                String               @db.VarChar(512) // RFC5545
  tzid                 String               @db.VarChar(100) // p.ej. "Europe/Madrid"
  rdates               Json?                @db.Json
  recurrenceStatusType RecurrenceStatusType @default(ACTIVE)
  idUserFk             String?

  createdDate DateTime  @default(now()) @db.Timestamptz(3)
  updatedDate DateTime  @updatedAt @db.Timestamptz(3)
  deletedDate DateTime?

  // Relación lógica con eventos a través de idRecurrenceRuleFk en Event
  events Event[] @relation("recurrenceRules")

  @@index([idWorkspaceFk])
  @@map("recurrenceRules")
}

// ────────────────────────────────────────────────────────────────────────────
//// SINCRONIZACIÓN EXTERNA (por evento)
// ────────────────────────────────────────────────────────────────────────────

model ExternalCalendarEvent {
  id               String   @id @default(uuid())
  idEventFk        String   @unique
  googleEventId    String?  @db.VarChar(512)
  microsoftEventId String?  @db.VarChar(512)
  createdDate      DateTime @default(now()) @db.Timestamptz(3)
  updatedDate      DateTime @updatedAt @db.Timestamptz(3)

  event Event @relation(fields: [idEventFk], references: [id], onDelete: Cascade)

  @@index([idEventFk])
  @@map("externalCalendarEvents")
}

// ────────────────────────────────────────────────────────────────────────────
// HORARIOS Y AUSENCIAS
// ────────────────────────────────────────────────────────────────────────────

model BusinessHour {
  id            String      @id @default(uuid())
  idCompanyFk   String
  idWorkspaceFk String      @default("")
  weekDayType   WeekDayType
  startTime     String?     @db.VarChar(5) // "HH:mm"
  endTime       String?     @db.VarChar(5) // "HH:mm"
  closed        Boolean     @default(false)
  createdDate   DateTime    @default(now())
  updatedDate   DateTime    @updatedAt
  deletedDate   DateTime?

  @@index([idCompanyFk])
  @@index([idWorkspaceFk])
  @@map("businessHours")
}

model WorkerBusinessHour {
  id            String      @id @default(uuid())
  idUserFk      String
  idCompanyFk   String
  idWorkspaceFk String      @default("")
  weekDayType   WeekDayType
  startTime     String?     @db.VarChar(5) // "HH:mm"
  endTime       String?     @db.VarChar(5) // "HH:mm"
  closed        Boolean     @default(false)
  createdDate   DateTime    @default(now())
  updatedDate   DateTime    @updatedAt
  deletedDate   DateTime?

  @@index([idWorkspaceFk])
  @@index([idUserFk, idWorkspaceFk])
  @@map("workerBusinessHours")
}

model TemporaryBusinessHour {
  id            String    @id @default(uuid())
  title         String?   @db.VarChar(120)
  description   String?   @db.VarChar(256)
  idCompanyFk   String
  idWorkspaceFk String    @default("")
  idUserFk      String?
  idEventFk     String
  date          DateTime
  startTime     String?   @db.VarChar(5) // "HH:mm"
  endTime       String?   @db.VarChar(5) // "HH:mm"
  closed        Boolean   @default(false)
  createdDate   DateTime  @default(now()) @db.Timestamptz(3)
  updatedDate   DateTime  @default(now()) @updatedAt @db.Timestamptz(3)
  deletedDate   DateTime?

  event Event @relation(fields: [idEventFk], references: [id], onDelete: Cascade)

  @@index([idWorkspaceFk])
  @@index([idUserFk, idWorkspaceFk])
  @@map("temporaryBusinessHours")
}

model WorkerAbsence {
  id               String           @id @default(uuid())
  idUserFk         String?
  idCompanyFk      String
  idWorkspaceFk    String           @default("")
  description      String?          @db.VarChar(256)
  createdDate      DateTime         @default(now()) @db.Timestamptz(3)
  updatedDate      DateTime         @default(now()) @updatedAt @db.Timestamptz(3)
  deletedDate      DateTime?
  idEventFk        String
  endDate          DateTime
  eventPurposeType EventPurposeType @default(SICK_LEAVE)
  startDate        DateTime
  title            String?          @db.VarChar(120)

  event Event @relation(fields: [idEventFk], references: [id], onDelete: Cascade)

  @@index([idWorkspaceFk])
  @@index([idUserFk, idWorkspaceFk])
  @@map("workerAbsences")
}

model WaitList {
  id              String    @id @default(uuid())
  idClientFk      String
  idWorkspaceFk   String
  startDate       DateTime  @db.Timestamptz(6)
  endDate         DateTime  @db.Timestamptz(6)
  messageWasSent  Boolean   @default(false)
  messageSentDate DateTime?
  vipLevel        Int       @default(0)
  createdDate     DateTime  @default(now())
  updatedDate     DateTime  @updatedAt
  deletedDate     DateTime?

  @@index([idWorkspaceFk])
  @@index([idClientFk])
  @@index([messageWasSent, endDate])
  @@index([vipLevel, createdDate])
  @@map("waitLists")
}

