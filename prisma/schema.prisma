generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Calendar {
  id            String    @id @default(uuid())
  idCompanyFk   String
  idWorkspaceFk String
  createdDate   DateTime  @default(now())
  updatedDate   DateTime  @updatedAt
  deletedDate   DateTime?

  event          Event[]
  RecurrenceRule RecurrenceRule[]

  @@unique([idCompanyFk, idWorkspaceFk])
  @@index([idCompanyFk])
  @@index([idWorkspaceFk])
  @@map("calendars")
}

model Event {
  id                 String          @id @default(uuid())
  title              String          @db.VarChar(256)
  description        String?         @db.VarChar(512)
  startDate          DateTime        @db.Timestamptz(6)
  endDate            DateTime        @db.Timestamptz(6)
  idCalendarFk       String
  idServiceFk        String?
  idUserPlatformFk   String?
  commentClient      String?         @db.VarChar(300)
  eventSourceType    EventSourceType @default(PLATFORM)
  isEditableByClient Boolean         @default(true)
  numberUpdates      Int?            @default(0)
  eventStatusType    EventStatusType @default(PENDING)
  timeZone           String          @default("Europe/Madrid") @db.VarChar(50)
  allDay             Boolean         @default(false)

  // Estos campos se utilizan para almacenar información del servicio
  // en el momento de la creación del evento, permitiendo que el evento sea independiente
  // de cambios futuros en el servicio.
  serviceNameSnapshot     String? @db.VarChar(100)
  servicePriceSnapshot    Float?
  serviceDiscountSnapshot Float?
  serviceDurationSnapshot Int?    @default(60) // duración en minutos

  createdDate        DateTime         @default(now())
  updatedDate        DateTime         @updatedAt
  deletedDate        DateTime?
  eventPurposeType   EventPurposeType @default(APPOINTMENT)
  idRecurrenceRuleFk String? // opcional: si es un evento recurrente, se relaciona con una regla de recurrencia
  // idClientWorkspaceFk String?
  // idClientFk              String?
  calendar           Calendar         @relation(fields: [idCalendarFk], references: [id])
  service            Service?         @relation(fields: [idServiceFk], references: [id])
  recurrenceRule     RecurrenceRule?  @relation("recurrenceRules", fields: [idRecurrenceRuleFk], references: [id])

  WorkerAbsence         WorkerAbsence[]
  ExternalCalendarEvent ExternalCalendarEvent?
  eventParticipant      EventParticipant[]

  // Para búsquedas por usuario + rango temporal (solapes)
  @@index([idUserPlatformFk, startDate, endDate], map: "idx_events_user_start_end")
  // Si también filtras a veces por fin de evento
  @@index([idUserPlatformFk, endDate], map: "idx_events_user_end")
  // (Opcional) Escaneos por tiempo: BRIN es baratísimo si la tabla es grande
  @@index([startDate], type: Brin, map: "idx_events_start_brin")
  @@index([idCalendarFk])
  @@index([idServiceFk])
  @@index([idUserPlatformFk])
  @@map("events")
}

model EventParticipant {
  id                  String          @id @default(uuid())
  idEventFk           String
  idClientWorkspaceFk String?
  idClientFk          String?
  eventStatusType     EventStatusType @default(PENDING)

  createdDate DateTime  @default(now()) @db.Timestamptz(3)
  updatedDate DateTime  @default(now()) @updatedAt @db.Timestamptz(3)
  deletedDate DateTime?

  event Event @relation(fields: [idEventFk], references: [id], onDelete: Cascade)

  @@index([idEventFk])
  @@map("eventParticipants")
}

model RecurrenceRule {
  id                   String               @id @default(uuid())
  idCalendarFk         String
  dtstart              DateTime             @db.Timestamptz(6) // fecha y hora de inicio de la serie
  until                DateTime?            @db.Timestamptz(6) // opcional: fecha tope de la recurrencia
  rrule                String               @db.VarChar(512) // texto RFC5545 completo
  tzid                 String               @db.VarChar(100) // p.ej. "Europe/Madrid"
  rdates               Json?                @db.Json
  recurrenceStatusType RecurrenceStatusType @default(ACTIVE) // opcional: estado de la recurrencia (p.ej. "active", "paused", "cancelled")
  idUserFk             String? // opcional: usuario que creó la regla de recurrencia

  createdDate DateTime  @default(now()) @db.Timestamptz(3)
  updatedDate DateTime  @updatedAt @db.Timestamptz(3)
  deletedDate DateTime?

  // Relaciones
  calendar Calendar @relation(fields: [idCalendarFk], references: [id])
  events   Event[]  @relation("recurrenceRules")

  @@index([idCalendarFk])
  @@map("recurrenceRules")
}

// Mapping table for external calendar IDs (Google and Microsoft/Teams share same Outlook ID)
model ExternalCalendarEvent {
  id               String   @id @default(uuid())
  idEventFk        String   @unique
  googleEventId    String?  @db.VarChar(512)
  microsoftEventId String?  @db.VarChar(512)
  createdDate      DateTime @default(now()) @db.Timestamptz(3)
  updatedDate      DateTime @updatedAt @db.Timestamptz(3)

  event Event @relation(fields: [idEventFk], references: [id], onDelete: Cascade)

  @@index([idEventFk])
  @@map("externalCalendarEvents")
}

model BusinessHour {
  id            String      @id @default(uuid())
  idCompanyFk   String
  idWorkspaceFk String      @default("")
  weekDayType   WeekDayType
  // startTime         DateTime?   @db.Time(6)
  // endTime           DateTime?   @db.Time(6)
  startTime     String?     @db.VarChar(5) // formato "HH:mm"
  endTime       String?     @db.VarChar(5) // formato "HH:mm
  closed        Boolean     @default(false)
  createdDate   DateTime    @default(now())
  updatedDate   DateTime    @updatedAt
  deletedDate   DateTime?

  @@index([idCompanyFk])
  @@index([idWorkspaceFk])
  @@map("businessHours")
}

model WorkerBusinessHour {
  id            String      @id @default(uuid())
  idUserFk      String
  idCompanyFk   String
  idWorkspaceFk String      @default("")
  weekDayType   WeekDayType
  // startTime         DateTime?   @db.Time(6)
  // endTime           DateTime?   @db.Time(6)
  startTime     String?     @db.VarChar(5) // formato "HH:mm"
  endTime       String?     @db.VarChar(5) // formato "HH:mm
  closed        Boolean     @default(false)
  createdDate   DateTime    @default(now())
  updatedDate   DateTime    @updatedAt
  deletedDate   DateTime?

  @@index([idWorkspaceFk])
  @@index([idUserFk, idWorkspaceFk])
  @@map("workerBusinessHours")
}

model TemporaryBusinessHour {
  id            String    @id @default(uuid())
  idCompanyFk   String
  idWorkspaceFk String    @default("")
  idUserFk      String?
  date          DateTime
  // startTime         DateTime? @db.Time(6)
  // endTime           DateTime? @db.Time(6)
  startTime     String?   @db.VarChar(5) // formato "HH:mm"
  endTime       String?   @db.VarChar(5) // formato "HH:mm
  closed        Boolean   @default(false)
  createdDate   DateTime  @default(now()) @db.Timestamptz(3)
  updatedDate   DateTime  @default(now()) @updatedAt @db.Timestamptz(3)
  deletedDate   DateTime?

  @@index([idWorkspaceFk])
  @@index([idUserFk, idWorkspaceFk])
  @@map("temporaryBusinessHours")
}

model WorkerAbsence {
  id               String           @id @default(uuid())
  idUserFk         String?
  idCompanyFk      String
  idWorkspaceFk    String           @default("")
  description      String?          @db.VarChar(256)
  createdDate      DateTime         @default(now()) @db.Timestamptz(3)
  updatedDate      DateTime         @default(now()) @updatedAt @db.Timestamptz(3)
  deletedDate      DateTime?
  idEventFk        String
  endDate          DateTime
  eventPurposeType EventPurposeType @default(SICK_LEAVE)
  startDate        DateTime
  title            String?          @db.VarChar(100)
  event            Event            @relation(fields: [idEventFk], references: [id], onDelete: Cascade)

  @@index([idWorkspaceFk])
  @@index([idUserFk, idWorkspaceFk])
  @@map("workerAbsences")
}

// ——————————————————————————————————————————————
// Categorías **por** establecimiento
model Category {
  id                   String               @id @default(uuid())
  idCompanyFk          String
  idWorkspaceFk        String
  name                 String               @db.VarChar(100)
  description          String?              @db.VarChar(512)
  color                String               @default("#4d5fd6") @db.VarChar(10)
  position             Int?                 @default(0)
  moderationStatusType ModerationStatusType @default(PENDING)
  createdDate          DateTime             @default(now())
  updatedDate          DateTime             @default(now()) @updatedAt
  deletedDate          DateTime?

  categoryServices CategoryService[]

  @@unique([idWorkspaceFk, name])
  @@index([idWorkspaceFk])
  @@map("categories")
}

// ——————————————————————————————————————————————
// Servicios **por** establecimiento
model Service {
  id                   String               @id @default(uuid())
  idCompanyFk          String
  idWorkspaceFk        String
  image                String?              @db.VarChar(512)
  name                 String               @db.VarChar(100)
  description          String               @db.VarChar(512)
  duration             Int                  @default(60)
  price                Float                @default(0)
  discount             Float                @default(0)
  color                String               @default("#4d5fd6") @db.VarChar(10)
  isVisible            Boolean              @default(true)
  serviceType          ServiceType?         @default(AT_BUSINESS)
  maxParticipants      Int?                 @default(1)
  moderationStatusType ModerationStatusType @default(PENDING)
  createdDate          DateTime             @default(now())
  updatedDate          DateTime             @updatedAt
  deletedDate          DateTime?

  categoryServices CategoryService[]
  userServices     UserService[]
  event            Event[]

  @@unique([idWorkspaceFk, name])
  @@index([idWorkspaceFk])
  @@map("services")
}

// ——————————————————————————————————————————————
// Pivot “servicio ←→ categoría” dentro de cada establecimiento
model CategoryService {
  id           String    @id @default(uuid())
  idCategoryFk String
  idServiceFk  String
  position     Int?      @default(0)
  createdDate  DateTime  @default(now())
  updatedDate  DateTime  @updatedAt
  deletedDate  DateTime?

  category Category @relation(fields: [idCategoryFk], references: [id])
  service  Service  @relation(fields: [idServiceFk], references: [id])

  @@unique([idCategoryFk, idServiceFk])
  @@index([idServiceFk])
  @@map("categoryServiceAssignments")
}

model UserService {
  id          String    @id @default(uuid())
  idCompanyFk String
  idUserFk    String
  idServiceFk String
  createdDate DateTime  @default(now())
  updatedDate DateTime  @updatedAt
  deletedDate DateTime?
  service     Service   @relation(fields: [idServiceFk], references: [id])

  @@unique([idCompanyFk, idUserFk, idServiceFk])
  @@index([idCompanyFk])
  @@index([idUserFk])
  @@index([idServiceFk])
  @@map("userServices")
}

enum EventSourceType {
  PLATFORM
  BOT
  GOOGLE
}

enum ServiceType {
  AT_BUSINESS // cliente va al local
  VIRTUAL // videollamada o remoto
  AT_CLIENT // el proveedor se desplaza
}

enum EventStatusType {
  PENDING
  ACCEPTED
  CONFIRMED
  COMPLETED
  CANCELLED
  CANCELLED_BY_CLIENT
  CANCELLED_BY_CLIENT_REMOVED
  PAID
}

enum ModerationStatusType {
  PENDING
  ACCEPTED
  REJECTED
}

enum EventPurposeType {
  APPOINTMENT
  VACATION
  SICK_LEAVE
  PERSONAL_DAY
  UNPAID_LEAVE
  OTHER
}

enum WeekDayType {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum RecurrenceStatusType {
  ACTIVE
  PAUSED
  CANCELLED
}
