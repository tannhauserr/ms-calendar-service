{
  "compilerOptions": {
    "strictNullChecks": false,
    // "target": "es5",
    "target": "ES2019",
    "module": "commonjs",
    "lib": [
      "ES2019"
      // "es6"
    ],
    "allowJs": true,
    "outDir": "build",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": [
      "node",
      "jest"
    ],
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strictPropertyInitialization": false,
    "noImplicitAny": false,
    "downlevelIteration": true,
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "webpack.config.js",
    "build",
    "node_modules"
  ]
}
