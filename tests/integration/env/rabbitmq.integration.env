NODE_ENV=test
PORT=3298
LOG_LEVEL=error
INTEGRATIONS_MODE=http

ENABLE_REDIS=false
ENABLE_RABBITMQ=true

DATABASE_URL=postgresql://test_calendar:test_calendar@localhost:55432/ms_calendar?schema=public
WEB_WHITELIST_CORS=["http://localhost:4200"]

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0

RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5673
RABBITMQ_VHOST=/
RABBITMQ_PREFETCH=1

JWT_PRIVATE_KEY=test-private-key
TOKEN_MS_LOGIN=test-token-ms-login
TOKEN_MS_CATALOG=test-token-ms-catalog
TOKEN_CLIENT=test-token-client
TOKEN_MS_CALENDAR=test-token-ms-calendar

URL_BACK_MS_GATEWAY=http://localhost:3299
URL_BACK_MS_AUTH=http://localhost:3200
URL_NEXTJS=http://localhost:4202

REVALIDATE_TOKEN=test-revalidate-token
REVALIDATE_HMAC_SECRET=test-revalidate-hmac

DESCRYPT_KEY=test-encryption-key
DESCRYPT_KEY_VERSION=1
DEFAULT_ID_COMPANY_FK=itest-company
